const axios = require("axios");
const fs = require("fs");
const path = require("path");

/**
 * Comando: playvid2
 * Função: Buscar vídeo por nome, obter link do YouTube e baixar via API externa.
 * Versão Final: Estável, sem logs excessivos e com envio simplificado para garantir entrega.
 */
module.exports = async function playvid2Command(sock, from, Info, args, prefix) {
    const reply = (texto) => sock.sendMessage(from, { text: texto }, { quoted: Info });

    try {
        const query = args.join(" ").trim();
        if (!query) {
            return reply(`❌ Cadê o nome do vídeo ou o link do YouTube?\n\n*Exemplo:*\n${prefix}playvid2 Matuê - Crack com Mussilon`);
        }

        // Reação de busca
        await sock.sendMessage(from, { react: { text: "🔎", key: Info.key } });

        let videoUrl = "";
        let videoTitle = "";

        // Verificar se já é um link do YouTube
        const youtubeRegex = /(?:https?:\/\/)?(?:www\.)?(?:m\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/;
        const match = query.match(youtubeRegex);

        if (match) {
            videoUrl = match[0];
        } else {
            // Buscar pelo nome usando a API de pesquisa
            try {
                const searchRes = await axios.get("https://tedzinho.com.br/api/pesquisa/youtube", {
                    params: {
                        apikey: "J",
                        query: query
                    }
                });

                const resultados = searchRes.data?.resultado;
                if (resultados && resultados.length > 0) {
                    videoUrl = resultados[0].url;
                    videoTitle = resultados[0].title;
                }
            } catch (err) {}
        }

        if (!videoUrl) {
            await sock.sendMessage(from, { react: { text: "❌", key: Info.key } });
            return reply("❌ Não consegui encontrar nenhum vídeo com esse nome.");
        }

        // Reação de processamento
        await sock.sendMessage(from, { react: { text: "⏳", key: Info.key } });

        // Chamar a API de download
        const apiUrl = `https://systemzone.store/api/downloader/ytdl-v4?apikey=Tedsystem&url=${encodeURIComponent(videoUrl)}&type=mp4&quality=720`;
        
        const response = await axios.get(apiUrl);
        const data = response.data;

        if (!data || !data.status || !data.result || !data.result.download_url) {
            await sock.sendMessage(from, { react: { text: "❌", key: Info.key } });
            return reply("⚠️ Erro ao obter o link de download da API. Tente novamente mais tarde.");
        }

        const result = data.result;
        const downloadUrl = result.download_url;
        const title = result.title || videoTitle || "Vídeo do YouTube";

        // Reação de baixando
        await sock.sendMessage(from, { react: { text: "📥", key: Info.key } });
        
        // Caminho temporário para o vídeo
        const tempDir = path.join(__dirname, '../../temp');
        if (!fs.existsSync(tempDir)) fs.mkdirSync(tempDir, { recursive: true });
        
        const tempPath = path.join(tempDir, `video_${Date.now()}.mp4`);

        // Baixar o arquivo
        const writer = fs.createWriteStream(tempPath);
        const videoDownload = await axios({
            method: 'get',
            url: downloadUrl,
            responseType: 'stream'
        });

        videoDownload.data.pipe(writer);

        await new Promise((resolve, reject) => {
            writer.on('finish', resolve);
            writer.on('error', reject);
        });

        const stats = fs.statSync(tempPath);
        if (stats.size > 100 * 1024 * 1024) { // Limite de 100MB
            fs.unlinkSync(tempPath);
            await sock.sendMessage(from, { react: { text: "❌", key: Info.key } });
            return reply("⚠️ O vídeo é muito grande (maior que 100MB) para ser enviado pelo WhatsApp.");
        }

        // Reação de enviando
        await sock.sendMessage(from, { react: { text: "📤", key: Info.key } });

        // Enviar o vídeo de forma simplificada para garantir a entrega
        try {
            const videoBuffer = fs.readFileSync(tempPath);
            
            await sock.sendMessage(from, {
                video: videoBuffer,
                mimetype: "video/mp4",
                caption: `🎬 *${title}*\n\n🔗 *Link:* ${videoUrl}`,
                fileName: `${title.replace(/[^\w\s.-]/gi, "")}.mp4`
            }, { quoted: Info });

            // Reação final
            await sock.sendMessage(from, { react: { text: "✅", key: Info.key } });

        } catch (sendError) {
            throw sendError;
        } finally {
            // Aguardar 10 segundos antes de apagar para garantir que o Baileys terminou de processar
            setTimeout(() => {
                if (fs.existsSync(tempPath)) {
                    fs.unlinkSync(tempPath);
                }
            }, 10000);
        }

    } catch (e) {
        await sock.sendMessage(from, { react: { text: "❌", key: Info.key } });
        await reply("❌ Ocorreu um erro ao processar seu vídeo. Verifique se o servidor tem espaço em disco ou se o vídeo é suportado.");
        
        // Limpeza de arquivos antigos em caso de erro
        try {
            const tempDir = path.join(__dirname, '../../temp');
            if (fs.existsSync(tempDir)) {
                const files = fs.readdirSync(tempDir);
                files.forEach(file => {
                    if (file.startsWith('video_') && file.endsWith('.mp4')) {
                        const filePath = path.join(tempDir, file);
                        const stats = fs.statSync(filePath);
                        if (Date.now() - stats.mtimeMs > 300000) { // 5 minutos
                            fs.unlinkSync(filePath);
                        }
                    }
                });
            }
        } catch (err) {}
    }
};
